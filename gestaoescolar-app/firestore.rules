rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function perfil() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil;
    }

    function isPerfil(p) {
      return isAuth() && perfil() == p;
    }

    function isAnyOf(perfis) {
      return isAuth() && perfil() in perfis;
    }

    function isAtivo() {
      return isAuth() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.ativo == true;
    }

    function hasMinhasTurmas(turmaId) {
      return turmaId in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.turmas_ids;
    }

    // ── /usuarios ────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if isAtivo() && (request.auth.uid == uid || isAnyOf(['diretor', 'admin', 'coordenador']));
      allow create: if isAtivo() && isAnyOf(['diretor', 'admin']);
      allow update: if isAtivo() && (
        // Próprio usuário atualiza apenas ultimo_acesso
        (request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ultimo_acesso']))
        // Diretor/Admin atualizam tudo exceto UID
        || isAnyOf(['diretor', 'admin'])
      );
      allow delete: if false;
    }

    // ── /alunos ──────────────────────────────────────────────────────────
    match /alunos/{alunoId} {
      allow read:   if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow create: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /responsaveis ────────────────────────────────────────────────────
    match /responsaveis/{respId} {
      allow read:   if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow create: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /matriculas ──────────────────────────────────────────────────────
    match /matriculas/{matId} {
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(resource.data.turma_id))
      );
      allow create: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /turmas ──────────────────────────────────────────────────────────
    match /turmas/{turmaId} {
      // C-4 QA: professor só lê turmas das quais faz parte
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria'])
        || (isPerfil('professor') && hasMinhasTurmas(turmaId))
      );
      allow create: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /disciplinas ─────────────────────────────────────────────────────
    match /disciplinas/{discId} {
      allow read: if isAtivo();
      allow create: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /calendario ──────────────────────────────────────────────────────
    match /calendario/{calId} {
      allow read: if isAtivo();
      allow write: if isAtivo() && isAnyOf(['diretor', 'admin']);
    }

    // ── /presencas ───────────────────────────────────────────────────────
    match /presencas/{presId} {
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(resource.data.turma_id))
      );
      allow create: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(request.resource.data.turma_id))
      );
      // Edição: professor só dentro do prazo de 48h; coord/diretor sempre
      allow update: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor')
            && hasMinhasTurmas(resource.data.turma_id)
            && resource.data.editavel_ate > request.time)
      );
      allow delete: if false;
    }

    // ── /avaliacoes ──────────────────────────────────────────────────────
    match /avaliacoes/{avalId} {
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(resource.data.turma_id))
      );
      allow create: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(request.resource.data.turma_id))
      );
      allow update: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(resource.data.turma_id))
      );
      allow delete: if false;
    }

    // ── /notas ───────────────────────────────────────────────────────────
    match /notas/{notaId} {
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(resource.data.turma_id))
      );
      allow create: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor') && hasMinhasTurmas(request.resource.data.turma_id))
      );
      // Professor só edita se bimestre não fechado; coord/diretor sempre
      allow update: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor')
            && hasMinhasTurmas(resource.data.turma_id)
            && resource.data.fechado == false)
      );
      allow delete: if false;
    }

    // ── /ocorrencias ─────────────────────────────────────────────────────
    match /ocorrencias/{ocorId} {
      allow read: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor')
            && resource.data.tipo != 'medico'
            && resource.data.tipo != 'acidente'
            && hasMinhasTurmas(resource.data.turma_id))
      );
      // S-4 QA: professor não pode criar ocorrências médicas nem de acidente
      allow create: if isAtivo() && (
        isAnyOf(['diretor', 'coordenador'])
        || (isPerfil('professor')
            && request.resource.data.tipo != 'medico'
            && request.resource.data.tipo != 'acidente')
      );
      allow update: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
      allow delete: if false;
    }

    // ── /financeiro_lancamentos ──────────────────────────────────────────
    match /financeiro_lancamentos/{lancId} {
      allow read:   if isAtivo() && isAnyOf(['diretor', 'admin']);
      allow create: if isAtivo() && isPerfil('admin');
      allow update: if isAtivo() && isAnyOf(['diretor', 'admin']);
      allow delete: if false;
    }

    // ── /projetos ────────────────────────────────────────────────────────
    match /projetos/{projId} {
      allow read:  if isAtivo() && isAnyOf(['diretor', 'coordenador', 'admin']);
      allow write: if isAtivo() && isAnyOf(['diretor', 'coordenador']);
    }

    // ── /pendencias ──────────────────────────────────────────────────────
    match /pendencias/{pendId} {
      allow read:  if isAtivo() && isAnyOf(['diretor', 'coordenador', 'admin']);
      allow write: if isAtivo() && isAnyOf(['diretor', 'coordenador', 'admin']);
    }

    // ── /notificacoes ────────────────────────────────────────────────────
    match /notificacoes/{notifId} {
      allow read:   if isAtivo() && resource.data.destinatario_id == request.auth.uid;
      allow update: if isAtivo() && resource.data.destinatario_id == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida']);
      allow create: if false; // Só Cloud Functions criam
      allow delete: if false;
    }

    // ── /indicadores ─────────────────────────────────────────────────────
    match /indicadores/{anoId} {
      allow read:  if isAtivo();
      allow write: if false; // Apenas Cloud Functions
    }

    // ── /auditoria ───────────────────────────────────────────────────────
    match /auditoria/{audId} {
      allow read:   if isAtivo() && isAnyOf(['diretor', 'admin']);
      allow write:  if false; // IMUTÁVEL — apenas Cloud Functions
    }

    // ── /configuracoes ───────────────────────────────────────────────────
    match /configuracoes/{confId} {
      allow read:  if isAtivo();
      allow write: if isAtivo() && isAnyOf(['diretor', 'admin']);
    }
  }
}
