rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function usuarioDoc() {
      return firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }

    function usuarioData() {
      return usuarioDoc().data;
    }

    function isAtivo() {
      return isAuth() && usuarioData().ativo == true;
    }

    function perfil() {
      return usuarioData().perfil;
    }

    function isAnyOf(perfis) {
      return isAtivo() && perfil() in perfis;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isDocumentUpload() {
      return request.resource != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    function hasMaxSize(maxBytes) {
      return request.resource != null && request.resource.size < maxBytes;
    }

    // Fotos e arquivos ligados a alunos/responsáveis deixam de ficar expostos
    // para qualquer usuário autenticado, mas preservam leitura para perfis do app.
    match /alunos/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria', 'professor']);
      allow write: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria'])
                   && isImageUpload()
                   && hasMaxSize(5 * 1024 * 1024);
    }

    match /responsaveis/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria']);
      allow write: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    // Comprovantes financeiros passam a seguir o mesmo recorte mais restritivo
    // já aplicado ao Firestore.
    match /comprovantes/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'admin']);
      allow write: if isAnyOf(['diretor', 'admin'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    match /financeiro/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'admin']);
      allow write: if isAnyOf(['diretor', 'admin'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    // Anexos sensíveis de matrícula/ocorrência deixam de ser acessíveis
    // genericamente por qualquer autenticado.
    match /matriculas/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria']);
      allow write: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    match /ocorrencias/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'coordenador', 'admin']);
      allow write: if isAnyOf(['diretor', 'coordenador', 'admin'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    match /anexos/{allPaths=**} {
      allow read: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria']);
      allow write: if isAnyOf(['diretor', 'coordenador', 'admin', 'secretaria'])
                   && isDocumentUpload()
                   && hasMaxSize(10 * 1024 * 1024);
    }

    // Fallback legado: mantém compatibilidade para caminhos ainda não
    // categorizados explicitamente pelo app.
    match /{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
